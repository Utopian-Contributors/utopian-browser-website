---
import Base from "../layouts/Base.astro";
---

<Base title="Download" description="Download Utopian Browser for macOS. Based on Firefox, built for efficiency and privacy.">
  <section class="px-6 py-32 md:py-48">
    <div class="max-w-7xl mx-auto text-center">
      <p class="font-mono text-xs uppercase tracking-widest text-neutral-400 mb-6">
        Get started
      </p>
      <h1 class="text-4xl md:text-6xl font-bold tracking-tight mb-6">
        Download the Utopian Browser
      </h1>
      <p class="text-neutral-500 text-lg md:text-xl mb-4">
        Version 1.0 for macOS
      </p>
      <p class="font-mono text-sm text-neutral-400 mb-8">
        Based on Firefox 150.0 &middot; en-US &middot; .dmg
      </p>
      <p class="text-neutral-500 text-sm mb-12">
        Currently only available for Apple Silicon (ARM) Macs.
      </p>
      <a
        href="https://utopian-mar-host.fra1.cdn.digitaloceanspaces.com/utopian-150.0.en-US.mac.dmg"
        class="btn-primary"
      >
        Download for macOS &rarr;
      </a>
    </div>
  </section>
</Base>
