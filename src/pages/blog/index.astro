---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import Base from "../../layouts/Base.astro";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
---

<Base title="Blog">
  <section class="pt-24 pb-16 px-6">
    <div class="max-w-7xl mx-auto">
      <h1 class="text-3xl md:text-5xl font-bold tracking-tight mb-4">
        Blog
      </h1>
      <p class="text-neutral-500 mb-12">
        Technical writing on performance, privacy, and the economics of the web.
      </p>

      <div class="border-t border-neutral-200">
        {posts.map((post) => (
          <a
            href={`/blog/${post.id}`}
            class="flex flex-col md:flex-row md:items-center gap-6 py-10 border-b border-neutral-200 group"
          >
            <div class="flex-1">
              <h2 class="text-xl md:text-2xl font-bold group-hover:text-green-500 transition-colors mb-2">
                {post.data.title}
              </h2>
              <p class="text-neutral-500 mb-3">{post.data.excerpt}</p>
              <div class="flex items-center gap-3 text-xs font-mono text-neutral-400">
                {post.data.tags.length > 0 && (
                  <span>{post.data.tags[0]}</span>
                )}
                <span>·</span>
                <span>
                  {post.data.date.toLocaleDateString("en-US", {
                    day: "numeric",
                    month: "short",
                    year: "numeric",
                  })}
                </span>
              </div>
            </div>
            {post.data.image && (
              <Image
                src={post.data.image}
                alt={post.data.title}
                widths={[224, 448]}
                sizes="(min-width: 768px) 224px, 100vw"
                format="webp"
                quality={75}
                class="w-full md:w-56 h-36 object-cover shrink-0"
                loading="lazy"
              />
            )}
          </a>
        ))}
      </div>
    </div>
  </section>
</Base>
